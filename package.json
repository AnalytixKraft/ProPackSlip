{
  "name": "packpro-slip",
  "version": "0.1.1",
  "author": "www.analytixkraft.tech",
  "private": true,
  "main": "desktop/main.js",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": "24.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "electron",
      "prisma",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "node scripts/run-next-with-port.js dev",
    "build": "next build",
    "start": "node scripts/run-next-with-port.js start",
    "server:start": "node scripts/start-server.js",
    "server:stop": "node scripts/stop-server.js",
    "stack:up": "node scripts/start-server.js",
    "stack:down": "node scripts/stop-server.js",
    "lint": "next lint",
    "prisma": "prisma",
    "desktop": "electron .",
    "desktop:dev": "node scripts/desktop-dev.js",
    "desktop:prepare": "node desktop/scripts/prepare-desktop.js",
    "desktop:dist": "pnpm desktop:prepare && electron-builder --mac --x64 --win --x64",
    "desktop:mac": "pnpm desktop:prepare && electron-builder --mac --x64",
    "desktop:win": "pnpm desktop:prepare && electron-builder --win --x64",
    "desktop:win:portable": "pnpm desktop:prepare && electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.packproslip.desktop",
    "productName": "PackPro Slip",
    "asar": false,
    "asarUnpack": [
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/engines/**/*"
    ],
    "files": [
      "desktop/**/*",
      ".next/**/*",
      "public/**/*",
      "node_modules/**/*",
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/client/.prisma/**/*",
      "next.config.js",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "artifactName": "PackPro Slip-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "icon": "public/Logo.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "PackPro Slip"
    }
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "13.4.19",
    "playwright": "1.39.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "recharts": "^2.15.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "16.18.60",
    "@types/react": "18.2.28",
    "@types/react-dom": "18.2.13",
    "concurrently": "^8.2.2",
    "electron": "^25.8.4",
    "electron-builder": "^24.13.3",
    "eslint": "8.51.0",
    "eslint-config-next": "13.4.19",
    "prisma": "^5.22.0",
    "typescript": "5.2.2",
    "wait-on": "^7.0.1"
  }
}
